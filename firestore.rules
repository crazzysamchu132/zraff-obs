rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Bypass authentication restrictions since the frontend login system is completely removed
    // and access is controlled via password on the client side.
    function isAuthenticated() {
      return true;
    }
    
    function hasRole(role) {
      return true;
    }
    
    function isAdmin() {
      return true;
    }
    
    function isManager() {
      return true;
    }
    
    function isOperator() {
      return true;
    }

    // Users Collection
    match /users/{userId} {
      allow read, write: if true;
    }

    // Tournaments Collection
    match /tournaments/{tournamentId} {
      allow read, write: if true;
    }

    // Teams Collection
    match /teams/{teamId} {
      allow read, write: if true;
    }

    // Groups Collection
    match /groups/{groupId} {
      allow read, write: if true;
    }

    // Fixtures / Matches Collection
    match /fixtures/{fixtureId} {
      allow read, write: if true;
    }

    // Settings Collection
    match /settings/{settingsId} {
      allow read, write: if true;
    }

    // Graphics Overlay Control Collection
    match /graphics/{graphicsId} {
      allow read, write: if true;
    }

    // System Logs Collection
    match /system_logs/{logId} {
      allow read, write: if true;
    }
  }
}
